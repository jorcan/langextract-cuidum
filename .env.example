# LangExtract-Cuidum — Database connections
# Add these to your environment or .env file before running.

# Cuidum Odoo DB (read-only — source of transcriptions)
# CUIDUM_DB_URL=postgresql://user:pass@clientes.cuidum.com:5432/prod

# n8n_odoo (read-write — destination for extraction results)
# N8N_DB_URL=postgresql://user:pass@54.37.8.90:5432/n8n_odoo
